SLACK_APP_TOKEN=xapp-...
# Bot token scopes required: chat:write, reactions:read, reactions:write,
# channels:history. users:read + users:read.email are needed to auto-assign the
# filed Jira ticket to the proposal's author (the bot maps Slack email → Jira
# account); without them the ticket files unassigned.
SLACK_BOT_TOKEN=xoxb-...
WATCHED_CHANNELS=C0123ABCDEF
JIRA_BASE_URL=https://qumulo.atlassian.net
JIRA_EMAIL=vuifhaolain@qumulo.com
JIRA_API_TOKEN=
# Optional: overrides the qork_projects list in projects.yaml when set.
JIRA_QORK_PROJECTS=QORK
APPROVAL_THRESHOLD=3
# Messages shorter than this many words are ignored before the Claude proposal
# judge runs (cheap noise filter on the Slack event path).
PROPOSAL_MIN_WORDS=4
REMINDER_INTERVAL_DAYS=3
WARNING_AT_DAYS=10
ARCHIVE_GRACE_DAYS=3
WORKERS=2
QUEUE_SIZE=64
SQLITE_PATH=/data/state.db
HEALTH_PORT=8080
TRIGGER_TOKEN=
# External URL of the dashboard, used to link "Review the full proposal" in
# Slack. Leave blank to omit the link.
PUBLIC_BASE_URL=
